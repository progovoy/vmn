FROM progovoy/ubuntu_xenial_python3.6
RUN apt update && apt install -y git wget curl
# Install uv
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"
COPY pyproject.toml uv.lock /var/
COPY version_stamp /var/version_stamp/
WORKDIR /var
# Note: Python 3.6 may not be fully supported - fallback to pip if needed
RUN uv pip install --system -e ".[dev]" || pip3 install -e ".[dev]"
RUN git config --global user.email "you@example.com"
RUN git config --global user.name "Your Name"
