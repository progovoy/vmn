FROM ubuntu:focal

ARG USER_ID=1000
ARG GROUP_ID=1000
ARG VMN_VERSION
ARG VMN_GIT_TAG

RUN if getent group vmnuser ; then groupdel vmnuser; fi &&\
    groupadd -o -g ${GROUP_ID} vmnuser &&\
    useradd -l -u ${USER_ID} -g vmnuser vmnuser &&\
    install -d -m 0755 -o vmnuser -g vmnuser /home/vmnuser &&\
    chown --changes --silent --no-dereference --recursive \
          --from=33:33 ${USER_ID}:${GROUP_ID} \
        /home/vmnuser

RUN apt update && apt install -y python3-pip git
COPY stamp_with_${VMN_VERSION}_vmn.sh /

RUN git config --global user.email "you@example.com"
RUN git config --global user.name "Your Name"

RUN pip3 install "git+https://github.com/progovoy/vmn.git@${VMN_GIT_TAG}"

# Inject the real version — git installs leave version.py at 0.0.0
# because gen_ver.py only runs during PyPI wheel builds
RUN python3 -c "\
import version_stamp.version as v; \
import os; p = v.__file__; \
open(p, 'w').write('name = \"vmn\"\nversion = \"${VMN_VERSION}\"\n_version = \"${VMN_VERSION}\"\n')"

USER vmnuser
